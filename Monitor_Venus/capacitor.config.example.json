{
  "appId": "com.mtr.online",
  "appName": "Monitor",
  "webDir": "dist",
  "server": {
    "androidScheme": "https",
    "allowNavigation": [
      "mtr-online.com"
    ]
  },
  "android": {
    "allowMixedContent": true
  },
  "plugins": {
    "CapacitorHttp": {
      "enabled": true
    },
    "App": {
      "handlerUrl": "com.mtr.online://auth/google/callback"
    },
    "GoogleAuth": {
      "scopes": ["profile", "email"],
      "serverClientId": "YOUR_WEB_OAUTH_CLIENT_ID.apps.googleusercontent.com",
      "forceCodeForRefreshToken": true
    }
  }
}
